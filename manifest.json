{
  "manifest_version": 3,
  "name": "LinkedIn Solver",
  "version": "1.0",
  "description": "Helps solve the games on LinkedIn",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png", 
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
  {
    "matches": ["https://www.linkedin.com/*"],
    "js": ["content.js"],
    "all_frames": true

  }
  ]
}